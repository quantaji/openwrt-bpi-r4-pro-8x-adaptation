From 4349947a1d8d9d52cc6820fb8544ef41a47c5068 Mon Sep 17 00:00:00 2001
From: Bo-Cun Chen <bc-bocun.chen@mediatek.com>
Date: Thu, 18 Sep 2025 17:20:56 +0800
Subject: [PATCH] net: ethernet: mtk_eth_soc: add passive Ethernet mux support

Add MediaTek Ethernet passive mux glue for boards where one SerDes path
is physically switched between an RJ45 PHY and an SFP cage.  The mux uses
the SFP mod-def0 GPIO to detect module presence and a channel-select GPIO
to switch the external passive mux.

This is needed by BPI-R4 Pro 8X WAN combo:
  - channel 0: RJ45 through AS21xxx PHY28
  - channel 1: SFP2
  - sfp-present-channel = <1>, so SFP has priority when inserted

Source: direct BPI-R4 Pro 8X vendor tree
  target/linux/mediatek/patches-6.6/
  999-2708-net-ethernet-mtk_eth_soc-support-ethernet-passive-mu.patch
Source: MTK OpenWrt 25.12 feed
  target/linux/mediatek/patches-6.12/
  999-eth-06-mtk_eth_soc-support-ethernet-passive-mux.patch

Adaptation notes:
  - Keep direct 8X DTS property name "sfp-present-channel".
  - Also accept MTK RFB's "sfp-connected-channel" for compatibility.
  - Use kzalloc() and release the mux-bus node outside the child loop.
  - Keep this as 6.12 glue for M05; future upstream-style support can move
    to phy_port / port-state style APIs when available.

Signed-off-by: Bo-Cun Chen <bc-bocun.chen@mediatek.com>
Signed-off-by: Codex <codex@openai.com>
---
 drivers/net/ethernet/mediatek/mtk_eth_soc.c | 487 +++++++++++++++++++-
 drivers/net/ethernet/mediatek/mtk_eth_soc.h |  29 ++
 2 files changed, 515 insertions(+), 1 deletion(-)

--- a/drivers/net/ethernet/mediatek/mtk_eth_soc.c
+++ b/drivers/net/ethernet/mediatek/mtk_eth_soc.c
@@ -26,6 +26,7 @@
 #include <linux/pcs/pcs-mtk-lynxi.h>
 #include <linux/pcs/pcs-mtk-usxgmii.h>
 #include <linux/phy/phy.h>
+#include <linux/gpio/consumer.h>
 #include <linux/jhash.h>
 #include <linux/bitfield.h>
 #include <net/dsa.h>
@@ -5114,6 +5115,469 @@ static const struct net_device_ops mtk_n
 	.ndo_select_queue	= mtk_select_queue,
 };
 
+static void mtk_mux_put_channels(struct mtk_mux *mux)
+{
+	int i;
+
+	for (i = 0; i < MTK_MUX_CHANNELS_MAX; i++) {
+		of_node_put(mux->channels[i].of_node);
+		mux->channels[i].of_node = NULL;
+	}
+}
+
+static int mtk_mux_read_sfp_present(struct mtk_mux *mux, bool *present)
+{
+	int val;
+
+	val = gpiod_get_value_cansleep(mux->mod_def0_gpio);
+	if (val < 0)
+		return val;
+
+	*present = !!val;
+	return 0;
+}
+
+static unsigned int mtk_mux_choose_channel(struct mtk_mux *mux,
+					  bool sfp_present)
+{
+	return sfp_present ? mux->sfp_channel : mux->rj45_channel;
+}
+
+static bool mtk_mux_is_running(struct mtk_mux *mux)
+{
+	struct mtk_mac *mac = mux->mac;
+	struct net_device *dev = mac->hw->netdev[mac->id];
+
+	return netif_running(dev);
+}
+
+static int mtk_mux_stop(struct mtk_mux *mux)
+{
+	struct mtk_mac *mac = mux->mac;
+	struct net_device *dev = mac->hw->netdev[mac->id];
+	int err;
+
+	if (!mac->phylink)
+		return 0;
+
+	rtnl_lock();
+	err = mtk_stop(dev);
+	rtnl_unlock();
+
+	return err;
+}
+
+static void mtk_mux_disconnect(struct mtk_mux *mux)
+{
+	struct mtk_mac *mac = mux->mac;
+
+	if (mac->phylink) {
+		phylink_destroy(mac->phylink);
+		mac->phylink = NULL;
+	}
+}
+
+static int mtk_mux_select_channel(struct mtk_mux *mux, unsigned int channel)
+{
+	struct mtk_mac *mac = mux->mac;
+	struct mtk_eth *eth = mac->hw;
+	struct mtk_mux_channel *chan;
+
+	if (channel >= MTK_MUX_CHANNELS_MAX)
+		return -EINVAL;
+
+	chan = &mux->channels[channel];
+	if (!chan->of_node) {
+		dev_err(eth->dev, "Ethernet mux: channel %u has no DT node\n",
+			channel);
+		return -EINVAL;
+	}
+
+	gpiod_set_value_cansleep(mux->chan_sel_gpio, channel);
+	mac->of_node = chan->of_node;
+	mux->selected_channel = channel;
+
+	return 0;
+}
+
+static int mtk_mux_connect(struct mtk_mux *mux, unsigned int channel)
+{
+	struct mtk_mac *mac = mux->mac;
+	struct mtk_eth *eth = mac->hw;
+	struct mtk_mux_channel *chan = &mux->channels[channel];
+	struct phylink *pl;
+
+	pl = phylink_create(&mac->phylink_config,
+			    of_fwnode_handle(chan->of_node),
+			    chan->phy_mode, &mtk_phylink_ops);
+	if (IS_ERR(pl)) {
+		dev_err(eth->dev,
+			"Ethernet mux: channel %u: create phylink failed\n",
+			channel);
+		return PTR_ERR(pl);
+	}
+
+	mac->phylink = pl;
+	return 0;
+}
+
+static int mtk_mux_start(struct mtk_mux *mux)
+{
+	struct mtk_mac *mac = mux->mac;
+	struct net_device *dev = mac->hw->netdev[mac->id];
+	int err;
+
+	if (!mac->phylink)
+		return -ENODEV;
+
+	rtnl_lock();
+	err = mtk_open(dev);
+	rtnl_unlock();
+
+	return err;
+}
+
+static int mtk_mux_apply_channel(struct mtk_mux *mux, unsigned int channel)
+{
+	int err;
+
+	mtk_mux_disconnect(mux);
+
+	err = mtk_mux_select_channel(mux, channel);
+	if (err)
+		return err;
+
+	return mtk_mux_connect(mux, channel);
+}
+
+static int mtk_mux_rollback_channel(struct mtk_mux *mux,
+				    unsigned int old_channel,
+				    bool restart)
+{
+	struct mtk_eth *eth = mux->mac->hw;
+	int err;
+
+	while (test_and_set_bit_lock(MTK_RESETTING, &eth->state))
+		cpu_relax();
+
+	err = mtk_mux_apply_channel(mux, old_channel);
+	clear_bit_unlock(MTK_RESETTING, &eth->state);
+	if (err)
+		return err;
+
+	if (restart)
+		err = mtk_mux_start(mux);
+
+	return err;
+}
+
+static int mtk_mux_switch_channel(struct mtk_mux *mux,
+				  unsigned int new_channel)
+{
+	struct mtk_eth *eth = mux->mac->hw;
+	unsigned int old_channel = mux->active_channel;
+	bool restart = mtk_mux_is_running(mux);
+	int err, rollback_err;
+
+	if (new_channel == old_channel)
+		return 0;
+
+	mux->switching = true;
+
+	if (restart) {
+		err = mtk_mux_stop(mux);
+		if (err)
+			goto out_fail;
+	}
+
+	while (test_and_set_bit_lock(MTK_RESETTING, &eth->state))
+		cpu_relax();
+
+	err = mtk_mux_apply_channel(mux, new_channel);
+	clear_bit_unlock(MTK_RESETTING, &eth->state);
+	if (err)
+		goto rollback;
+
+	if (restart) {
+		err = mtk_mux_start(mux);
+		if (err)
+			goto rollback;
+	}
+
+	mux->active_channel = new_channel;
+	mux->last_error = 0;
+	mux->switch_count++;
+	mux->switching = false;
+
+	dev_info(eth->dev, "Ethernet mux: switched channel %u -> %u\n",
+		 old_channel, new_channel);
+
+	return 0;
+
+rollback:
+	rollback_err = mtk_mux_rollback_channel(mux, old_channel, restart);
+	if (rollback_err)
+		dev_err(eth->dev,
+			"Ethernet mux: rollback to channel %u failed: %d\n",
+			old_channel, rollback_err);
+
+out_fail:
+	mux->last_error = err;
+	mux->switching = false;
+	dev_warn_ratelimited(eth->dev,
+			     "Ethernet mux: switch channel %u -> %u failed: %d\n",
+			     old_channel, new_channel, err);
+
+	return err;
+}
+
+static void mtk_mux_poll(struct work_struct *work)
+{
+	struct mtk_mux *mux = container_of(work, struct mtk_mux, poll.work);
+	struct mtk_eth *eth = mux->mac->hw;
+	unsigned int new_channel;
+	bool sfp_present;
+	int err;
+
+	err = mtk_mux_read_sfp_present(mux, &sfp_present);
+	if (err) {
+		mux->last_error = err;
+		dev_warn_ratelimited(eth->dev,
+				     "Ethernet mux: failed to read MOD_DEF0: %d\n",
+				     err);
+		goto reschedule;
+	}
+
+	new_channel = mtk_mux_choose_channel(mux, sfp_present);
+	if (!mux->sfp_present_valid ||
+	    mux->last_sfp_present != sfp_present) {
+		dev_info(eth->dev,
+			 "Ethernet mux: MOD_DEF0 SFP present=%u, desired channel %u\n",
+			 sfp_present, new_channel);
+		mux->sfp_present_valid = true;
+	}
+
+	mux->last_sfp_present = sfp_present;
+	mux->desired_channel = new_channel;
+
+	if (mux->switching || mux->active_channel == new_channel ||
+	    !mtk_mux_is_running(mux))
+		goto reschedule;
+
+	mtk_mux_switch_channel(mux, new_channel);
+
+reschedule:
+	mod_delayed_work(system_wq, &mux->poll, msecs_to_jiffies(100));
+}
+
+static int mtk_mux_parse_channel(struct mtk_mux *mux, struct device_node *np)
+{
+	const __be32 *_id = of_get_property(np, "reg", NULL);
+	struct mtk_eth *eth = mux->mac->hw;
+	phy_interface_t phy_mode;
+	int id, err;
+
+	if (!_id) {
+		dev_err(eth->dev, "Ethernet mux: missing mux channel id\n");
+		return -EINVAL;
+	}
+
+	id = be32_to_cpup(_id);
+	if (id < 0 || id >= MTK_MUX_CHANNELS_MAX) {
+		dev_err(eth->dev, "Ethernet mux: %d is not a valid mux channel id\n",
+			id);
+		return -EINVAL;
+	}
+
+	err = of_get_phy_mode(np, &phy_mode);
+	if (err) {
+		dev_err(eth->dev, "Ethernet mux: invalid phy-mode for channel %d\n",
+			id);
+		return -EINVAL;
+	}
+
+	of_node_put(mux->channels[id].of_node);
+	mux->channels[id].of_node = of_node_get(np);
+	mux->channels[id].phy_mode = phy_mode;
+
+	return 0;
+}
+
+static int mtk_mux_validate_channels(struct mtk_mux *mux)
+{
+	struct mtk_eth *eth = mux->mac->hw;
+
+	if (mux->sfp_channel >= MTK_MUX_CHANNELS_MAX) {
+		dev_err(eth->dev, "Ethernet mux: invalid SFP channel %u\n",
+			mux->sfp_channel);
+		return -EINVAL;
+	}
+
+	if (mux->rj45_channel >= MTK_MUX_CHANNELS_MAX) {
+		dev_err(eth->dev, "Ethernet mux: invalid RJ45 channel %u\n",
+			mux->rj45_channel);
+		return -EINVAL;
+	}
+
+	if (mux->sfp_channel == mux->rj45_channel) {
+		dev_err(eth->dev,
+			"Ethernet mux: SFP and RJ45 cannot use channel %u\n",
+			mux->sfp_channel);
+		return -EINVAL;
+	}
+
+	if (!mux->channels[mux->rj45_channel].of_node ||
+	    !mux->channels[mux->sfp_channel].of_node) {
+		dev_err(eth->dev, "Ethernet mux: missing mux channel node\n");
+		return -EINVAL;
+	}
+
+	return 0;
+}
+
+static int mtk_mux_init_default(struct mtk_mux *mux)
+{
+	int err;
+
+	mux->active_channel = mux->rj45_channel;
+	mux->desired_channel = mux->rj45_channel;
+
+	err = mtk_mux_apply_channel(mux, mux->rj45_channel);
+	if (err) {
+		mux->last_error = err;
+		return err;
+	}
+
+	return 0;
+}
+
+static void mtk_release_mux(struct mtk_eth *eth, int id)
+{
+	struct mtk_mux *mux;
+
+	if (id < 0 || id >= MTK_MAX_DEVS)
+		return;
+
+	mux = eth->mux[id];
+	if (!mux)
+		return;
+
+	cancel_delayed_work_sync(&mux->poll);
+	mtk_mux_put_channels(mux);
+
+	if (!IS_ERR_OR_NULL(mux->mod_def0_gpio))
+		gpiod_put(mux->mod_def0_gpio);
+
+	if (!IS_ERR_OR_NULL(mux->chan_sel_gpio))
+		gpiod_put(mux->chan_sel_gpio);
+
+	kfree(mux);
+	eth->mux[id] = NULL;
+}
+
+static void mtk_release_all_muxes(struct mtk_eth *eth)
+{
+	int i;
+
+	for (i = 0; i < MTK_MAX_DEVS; i++)
+		mtk_release_mux(eth, i);
+}
+
+static int mtk_add_mux(struct mtk_eth *eth, struct device_node *np)
+{
+	const __be32 *_id = of_get_property(np, "reg", NULL);
+	struct device_node *child;
+	struct mtk_mux *mux;
+	unsigned int id;
+	int err;
+
+	if (!_id) {
+		dev_err(eth->dev, "Ethernet mux: missing attach mac id\n");
+		return -EINVAL;
+	}
+
+	id = be32_to_cpup(_id);
+	if (id >= MTK_MAX_DEVS) {
+		dev_err(eth->dev, "Ethernet mux: %d is not a valid attach mac id\n",
+			id);
+		return -EINVAL;
+	}
+
+	if (!eth->mac[id]) {
+		dev_err(eth->dev, "Ethernet mux: missing attached mac %u\n", id);
+		return -EINVAL;
+	}
+
+	mux = kzalloc(sizeof(*mux), GFP_KERNEL);
+	if (!mux)
+		return -ENOMEM;
+
+	eth->mux[id] = mux;
+	mux->mac = eth->mac[id];
+
+	mux->mod_def0_gpio = fwnode_gpiod_get_index(of_fwnode_handle(np),
+				"mod-def0", 0, GPIOD_IN |
+				GPIOD_FLAGS_BIT_NONEXCLUSIVE, "?");
+	if (IS_ERR(mux->mod_def0_gpio)) {
+		dev_err(eth->dev,
+			"Ethernet mux: failed to request gpio for mod-def0\n");
+		err = PTR_ERR(mux->mod_def0_gpio);
+		goto err_free_mux;
+	}
+
+	mux->chan_sel_gpio = fwnode_gpiod_get_index(of_fwnode_handle(np),
+				"chan-sel", 0, GPIOD_OUT_LOW, "?");
+	if (IS_ERR(mux->chan_sel_gpio)) {
+		dev_err(eth->dev,
+			"Ethernet mux: failed to request gpio for chan-sel\n");
+		err = PTR_ERR(mux->chan_sel_gpio);
+		goto err_put_mod_def0;
+	}
+
+	if (of_property_read_u32(np, "sfp-present-channel",
+				 &mux->sfp_channel) &&
+	    of_property_read_u32(np, "sfp-connected-channel",
+				 &mux->sfp_channel))
+		mux->sfp_channel = 1;
+	mux->rj45_channel = !mux->sfp_channel;
+
+	for_each_child_of_node(np, child) {
+		err = mtk_mux_parse_channel(mux, child);
+		if (err) {
+			dev_err(eth->dev, "Ethernet mux: failed to add mux channel\n");
+			of_node_put(child);
+			goto err_put_channels;
+		}
+	}
+
+	err = mtk_mux_validate_channels(mux);
+	if (err)
+		goto err_put_channels;
+
+	err = mtk_mux_init_default(mux);
+	if (err)
+		goto err_put_channels;
+
+	INIT_DELAYED_WORK(&mux->poll, mtk_mux_poll);
+	mod_delayed_work(system_wq, &mux->poll, msecs_to_jiffies(100));
+
+	dev_info(eth->dev,
+		 "Ethernet mux: RJ45 channel %u, SFP channel %u, MOD_DEF0 poll 100 ms\n",
+		 mux->rj45_channel, mux->sfp_channel);
+
+	return 0;
+
+err_put_channels:
+	mtk_mux_put_channels(mux);
+	gpiod_put(mux->chan_sel_gpio);
+err_put_mod_def0:
+	gpiod_put(mux->mod_def0_gpio);
+err_free_mux:
+	kfree(mux);
+	eth->mux[id] = NULL;
+	return err;
+}
+
 static int mtk_add_mac(struct mtk_eth *eth, struct device_node *np)
 {
 	const __be32 *_id = of_get_property(np, "reg", NULL);
@@ -5413,7 +5644,7 @@ static int mtk_sgmii_init(struct mtk_eth
 static int mtk_probe(struct platform_device *pdev)
 {
 	struct resource *res = NULL, *res_sram;
-	struct device_node *mac_np;
+	struct device_node *mac_np, *mux_np;
 	struct mtk_eth *eth;
 	int err, i;
 
@@ -5653,6 +5884,25 @@ static int mtk_probe(struct platform_dev
 			goto err_free_dev;
 	}
 
+	mux_np = of_get_child_by_name(eth->dev->of_node, "mux-bus");
+	if (mux_np) {
+		struct device_node *child;
+
+		for_each_available_child_of_node(mux_np, child) {
+			if (!of_device_is_compatible(child,
+						     "mediatek,eth-mux"))
+				continue;
+
+			err = mtk_add_mux(eth, child);
+			if (err)
+				dev_err(&pdev->dev,
+					"failed to add Ethernet mux %pOF: %d\n",
+					child, err);
+		}
+
+		of_node_put(mux_np);
+	}
+
 	if (eth->soc->offload_version) {
 		u8 ppe_num = eth->soc->ppe_num;
 
@@ -5712,6 +5966,7 @@ err_unreg_netdev:
 	mtk_unreg_dev(eth);
 err_deinit_ppe:
 	mtk_ppe_deinit(eth);
+	mtk_release_all_muxes(eth);
 	mtk_mdio_cleanup(eth);
 err_free_dev:
 	mtk_free_dev(eth);
@@ -5753,6 +6008,7 @@ static void mtk_remove(struct platform_d
 	mtk_cleanup(eth);
 	free_netdev(eth->dummy_dev);
 	mtk_mdio_cleanup(eth);
+	mtk_release_all_muxes(eth);
 }
 
 #define DESC_SIZE(struct_name)				\
--- a/drivers/net/ethernet/mediatek/mtk_eth_soc.h
+++ b/drivers/net/ethernet/mediatek/mtk_eth_soc.h
@@ -754,6 +754,7 @@ struct mtk_tx_dma_v2 {
 
 struct mtk_eth;
 struct mtk_mac;
+struct mtk_mux;
 
 struct mtk_xdp_stats {
 	u64 rx_xdp_redirect;
@@ -1409,6 +1410,7 @@ struct mtk_eth {
 	struct net_device		*dummy_dev;
 	struct net_device		*netdev[MTK_MAX_DEVS];
 	struct mtk_mac			*mac[MTK_MAX_DEVS];
+	struct mtk_mux			*mux[MTK_MAX_DEVS];
 	int				irq[3];
 	u32				msg_enable;
 	unsigned long			sysclk;
@@ -1494,6 +1496,33 @@ struct mtk_mac {
 	struct notifier_block		device_notifier;
 };
 
+#define MTK_MUX_CHANNELS_MAX	2
+
+/* struct mtk_mux_channel - private data for one passive mux channel */
+struct mtk_mux_channel {
+	struct device_node		*of_node;
+	phy_interface_t			phy_mode;
+};
+
+/* struct mtk_mux - private data for a passive Ethernet mux */
+struct mtk_mux {
+	struct delayed_work		poll;
+	struct gpio_desc		*mod_def0_gpio;
+	struct gpio_desc		*chan_sel_gpio;
+	struct mtk_mux_channel		channels[MTK_MUX_CHANNELS_MAX];
+	struct mtk_mac			*mac;
+	unsigned int			desired_channel;
+	unsigned int			selected_channel;
+	unsigned int			active_channel;
+	unsigned int			sfp_channel;
+	unsigned int			rj45_channel;
+	bool				last_sfp_present;
+	bool				sfp_present_valid;
+	bool				switching;
+	int				last_error;
+	unsigned int			switch_count;
+};
+
 /* the struct describing the SoC. these are declared in the soc_xyz.c files */
 extern const struct of_device_id of_mtk_match[];
 
