From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Codex <codex@openai.com>
Date: Mon, 15 Jun 2026 00:00:00 -0700
Subject: [PATCH] net: mediatek: add temporary M05.02 datapath diagnostics

TEMPORARY DIAGNOSTIC PATCH.

This patch is only for BPI-R4 Pro 8X M05.02 runtime fault isolation and
must be removed before the M05.02 implementation is finalized.  It does not
change PCS, PHY, MAC, mux, or link behavior.  It only reads existing PCS and
XGMAC/XFI-MIB registers and emits ratelimited diagnostic log lines.

Runtime symptom being investigated:
  - AS21xxx PHY28 / GMAC1 RJ45 path reports link and carrier.
  - eth1 transmits packets, but RX counters stay at zero and ARP fails.

The diagnostic lines are intended to distinguish whether the break is at the
USXGMII PCS lane, XGMAC force/TRX state, or XFI MAC counter path.

Signed-off-by: Codex <codex@openai.com>
---
 drivers/net/ethernet/mediatek/mtk_eth_soc.c | 49 ++++++++++++++++++++
 drivers/net/pcs/pcs-mtk-usxgmii.c           | 31 +++++++++++++
 2 files changed, 80 insertions(+)

--- a/drivers/net/pcs/pcs-mtk-usxgmii.c
+++ b/drivers/net/pcs/pcs-mtk-usxgmii.c
@@ -91,6 +91,28 @@ static void mtk_m32(struct mtk_usxgmii_p
 	iowrite32(val, mpcs->base + reg);
 }
 
+static void mtk_usxgmii_pcs_m05_diag(struct mtk_usxgmii_pcs *mpcs,
+				      const char *where,
+				      const struct phylink_link_state *state)
+{
+	u32 an_ctrl, an_sts, rx_sts, speed_ctrl;
+	bool pcs_link;
+
+	an_ctrl = mtk_r32(mpcs, RG_PCS_AN_CTRL0);
+	an_sts = mtk_r32(mpcs, RG_PCS_AN_STS0);
+	rx_sts = mtk_r32(mpcs, RG_PCS_RX_STATUS0);
+	speed_ctrl = mtk_r32(mpcs, RG_PHY_TOP_SPEED_CTRL1);
+	pcs_link = FIELD_GET(RG_PCS_RX_LINK_STATUS, rx_sts);
+
+	dev_info_ratelimited(mpcs->dev,
+			     "M05.02 temporary diag %s: if=%u neg=%#x state_link=%u state_speed=%d state_duplex=%d pcs_link=%u an_ctrl=%#x an_sts=%#x rx_status=%#x speed_ctrl=%#x\n",
+			     where, mpcs->interface, mpcs->neg_mode,
+			     state ? state->link : 0,
+			     state ? state->speed : SPEED_UNKNOWN,
+			     state ? state->duplex : DUPLEX_UNKNOWN,
+			     pcs_link, an_ctrl, an_sts, rx_sts, speed_ctrl);
+}
+
 static struct mtk_usxgmii_pcs *pcs_to_mtk_usxgmii_pcs(struct phylink_pcs *pcs)
 {
 	return container_of(pcs, struct mtk_usxgmii_pcs, pcs);
@@ -216,6 +238,8 @@ static int mtk_usxgmii_pcs_config(struct
 	if (ret)
 		return ret;
 
+	mtk_usxgmii_pcs_m05_diag(mpcs, "pcs_config", NULL);
+
 	return mode_changed;
 }
 
@@ -308,6 +332,8 @@ static void mtk_usxgmii_pcs_get_state(st
 	state->link = FIELD_GET(RG_PCS_RX_LINK_STATUS,
 				mtk_r32(mpcs, RG_PCS_RX_STATUS0));
 
+	mtk_usxgmii_pcs_m05_diag(mpcs, "pcs_get_state", state);
+
 	/* Continuously repeat re-configuration sequence until link comes up */
 	if (!state->link) {
 		mtk_usxgmii_pcs_config(pcs, mpcs->neg_mode,
@@ -343,6 +369,9 @@ static void mtk_usxgmii_pcs_link_up(stru
 	 * after the line side link up.
 	 */
 	mtk_usxgmii_pcs_config(pcs, neg_mode, interface, NULL, false);
+
+	mtk_usxgmii_pcs_m05_diag(pcs_to_mtk_usxgmii_pcs(pcs),
+				 "pcs_link_up", NULL);
 }
 
 static int mtk_usxgmii_pcs_enable(struct phylink_pcs *pcs)
--- a/drivers/net/ethernet/mediatek/mtk_eth_soc.c
+++ b/drivers/net/ethernet/mediatek/mtk_eth_soc.c
@@ -792,6 +792,43 @@ static void mtk_mac_link_down(struct phy
 	}
 }
 
+#define MTK_M05_XFI_TX_PKT_CNT		0x108
+#define MTK_M05_XFI_RX_PKT_CNT		0x188
+#define MTK_M05_XFI_RX_ETH_CNT		0x18c
+#define MTK_M05_XFI_RX_LEN_ERR_CNT	0x194
+#define MTK_M05_XFI_RX_CRC_ERR_CNT	0x198
+#define MTK_M05_XFI_RX_ALL_DROP_CNT	0x20c
+
+static void mtk_m05_diag_xgmac(struct mtk_mac *mac, const char *where,
+			       phy_interface_t interface, int speed, int duplex)
+{
+	struct mtk_eth *eth = mac->hw;
+	u32 xmac_base;
+
+	if (!mtk_is_netsys_v3_or_greater(eth) ||
+	    mac->id == MTK_GMAC1_ID ||
+	    interface == PHY_INTERFACE_MODE_INTERNAL ||
+	    !mtk_interface_mode_is_xgmii(interface))
+		return;
+
+	xmac_base = MTK_XMAC_MCR(mac->id);
+
+	dev_info_ratelimited(eth->dev,
+			     "M05.02 temporary diag %s: gmac%d if=%u speed=%d duplex=%d gdma_eg=%#x mac_mcr=%#x xmac_mcr=%#x xgmac_sts=%#x xmac_cnt_ctrl=%#x xfi_tx_pkt=%#x xfi_rx_pkt=%#x xfi_rx_eth=%#x xfi_rx_len_err=%#x xfi_rx_crc_err=%#x xfi_rx_drop=%#x\n",
+			     where, mac->id, interface, speed, duplex,
+			     mtk_r32(eth, MTK_GDMA_EG_CTRL(mac->id)),
+			     mtk_r32(eth, MTK_MAC_MCR(mac->id)),
+			     mtk_r32(eth, MTK_XMAC_MCR(mac->id)),
+			     mtk_r32(eth, MTK_XGMAC_STS(mac->id)),
+			     mtk_r32(eth, MTK_XMAC_CNT_CTRL(mac->id)),
+			     mtk_r32(eth, xmac_base + MTK_M05_XFI_TX_PKT_CNT),
+			     mtk_r32(eth, xmac_base + MTK_M05_XFI_RX_PKT_CNT),
+			     mtk_r32(eth, xmac_base + MTK_M05_XFI_RX_ETH_CNT),
+			     mtk_r32(eth, xmac_base + MTK_M05_XFI_RX_LEN_ERR_CNT),
+			     mtk_r32(eth, xmac_base + MTK_M05_XFI_RX_CRC_ERR_CNT),
+			     mtk_r32(eth, xmac_base + MTK_M05_XFI_RX_ALL_DROP_CNT));
+}
+
 static void mtk_set_queue_speed(struct mtk_eth *eth, unsigned int idx,
 				int speed)
 {
@@ -962,6 +1001,8 @@ static void mtk_xgdm_mac_link_up(struct
 		mcr |= XMAC_MCR_FORCE_RX_FC;
 
 	mtk_w32(mac->hw, mcr, MTK_XMAC_MCR(mac->id));
+
+	mtk_m05_diag_xgmac(mac, "xgdm_link_up", interface, speed, duplex);
 }
 
 static void mtk_mac_link_up(struct phylink_config *config,
@@ -974,6 +1015,8 @@ static void mtk_mac_link_up(struct phyli
 {
 	struct mtk_mac *mac = container_of(config, struct mtk_mac,
 					   phylink_config);
+	int diag_speed = speed;
+	int diag_duplex = duplex;
 
 	if (mtk_is_netsys_v3_or_greater(mac->hw) && mtk_interface_mode_is_xgmii(interface))
 		mtk_xgdm_mac_link_up(mac, phy, mode, interface, speed, duplex,
@@ -985,6 +1031,9 @@ static void mtk_mac_link_up(struct phyli
 	/* Repeat pextp setup to tune link */
 	if (mac->pextp)
 		phy_set_mode_ext(mac->pextp, PHY_MODE_ETHERNET, interface);
+
+	mtk_m05_diag_xgmac(mac, "mac_link_up_done", interface,
+			   diag_speed, diag_duplex);
 }
 
 static const struct phylink_mac_ops mtk_phylink_ops = {
