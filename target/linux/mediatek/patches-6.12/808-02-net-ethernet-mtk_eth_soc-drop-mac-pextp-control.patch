From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Codex <codex@openai.com>
Date: Mon, 15 Jun 2026 00:00:00 -0700
Subject: [PATCH] net: ethernet: mtk_eth_soc: drop MAC-owned XFI TPHY control

The MT7988 XFI TPHY is now described on the PCS nodes and managed by the
MediaTek USXGMII PCS driver.  Remove the older MAC-owned pextp control
path so the MAC and PCS layers do not both reset, power and retune the
same SerDes resource.

Keep the XGMAC force-mode/TRX setup in mtk_mac_prepare(), added by the
local M05.02 force-link fix, because that is MAC register state rather
than TPHY ownership.

Sources:
  - MTK OpenWrt 25.12 feed:
    target/linux/mediatek/patches-6.12/
    999-eth-02-mtk_eth_soc-remove-pextp-reset-for-SerDes-phy.patch
  - OpenWrt main 6.18 net/mediatek pending stack, whose MT7988 path no
    longer keeps this MAC-owned pextp chain.

Signed-off-by: Codex <codex@openai.com>
---
 drivers/net/ethernet/mediatek/mtk_eth_soc.c | 30 ----------------------------
 drivers/net/ethernet/mediatek/mtk_eth_soc.h |  1 -
 2 files changed, 31 deletions(-)

--- a/drivers/net/ethernet/mediatek/mtk_eth_soc.c
+++ b/drivers/net/ethernet/mediatek/mtk_eth_soc.c
@@ -23,7 +23,6 @@
 #include <linux/of_net.h>
 #include <linux/pcs/pcs-mtk-lynxi.h>
 #include <linux/pcs/pcs-mtk-usxgmii.h>
-#include <linux/phy/phy.h>
 #include <linux/gpio/consumer.h>
 #include <linux/jhash.h>
 #include <linux/bitfield.h>
@@ -765,9 +764,6 @@ static int mtk_mac_prepare(struct phylin
 			MTK_XGMAC_FORCE_MODE(mac->id), MTK_XGMAC_STS(mac->id));
 	}
 
-	if (mac->pextp && mac->interface != interface)
-		phy_reset(mac->pextp);
-
 	return 0;
 }
 
@@ -783,10 +779,6 @@ static int mtk_mac_finish(struct phylink
 	struct mtk_eth *eth = mac->hw;
 	u32 mcr_cur, mcr_new;
 
-	/* Setup PMA/PMD */
-	if (mac->pextp)
-		phy_set_mode_ext(mac->pextp, PHY_MODE_ETHERNET, interface);
-
 	/* Enable SGMII */
 	if (interface == PHY_INTERFACE_MODE_SGMII ||
 	    phy_interface_mode_is_8023z(interface))
@@ -1008,3 +1000,0 @@
-	/* Repeat pextp setup to tune link */
-	if (mac->pextp)
-		phy_set_mode_ext(mac->pextp, PHY_MODE_ETHERNET, interface);
@@ -3764,9 +3752,6 @@ static int mtk_open(struct net_device *d
 
 	ppe_num = eth->soc->ppe_num;
 
-	if (mac->pextp)
-		phy_power_on(mac->pextp);
-
 	err = phylink_of_phy_connect(mac->phylink, mac->of_node, 0);
 	if (err) {
 		netdev_err(dev, "%s: could not attach PHY: %d\n", __func__,
@@ -3918,9 +3903,6 @@ static int mtk_stop(struct net_device *d
 	for (i = 0; i < ARRAY_SIZE(eth->ppe); i++)
 		mtk_ppe_stop(eth->ppe[i]);
 
-	if (mac->pextp)
-		phy_power_off(mac->pextp);
-
 	return 0;
 }
 
@@ -5067,18 +5049,6 @@ static int mtk_add_mac(struct mtk_eth *e
 		}
 	}
 
-	if (mtk_is_netsys_v3_or_greater(eth) && (mac->sgmii_pcs || mac->usxgmii_pcs)) {
-		mac->pextp = devm_of_phy_optional_get(eth->dev, mac->of_node, NULL);
-		if (IS_ERR(mac->pextp)) {
-			if (PTR_ERR(mac->pextp) != -EPROBE_DEFER)
-				dev_err(eth->dev, "cannot get PHY, error %ld\n",
-					PTR_ERR(mac->pextp));
-
-			err = PTR_ERR(mac->pextp);
-			goto free_netdev;
-		}
-	}
-
 	memset(mac->hwlro_ip, 0, sizeof(mac->hwlro_ip));
 
 	eth->netdev[id]->irq = eth->irq[0];
--- a/drivers/net/ethernet/mediatek/mtk_eth_soc.h
+++ b/drivers/net/ethernet/mediatek/mtk_eth_soc.h
@@ -1400,7 +1400,6 @@ struct mtk_mac {
 	struct phylink_config		phylink_config;
 	struct phylink_pcs		*sgmii_pcs;
 	struct phylink_pcs		*usxgmii_pcs;
-	struct phy			*pextp;
 	struct mtk_eth			*hw;
 	struct mtk_hw_stats		*hw_stats;
 	__be32				hwlro_ip[MTK_MAX_LRO_IP_CNT];
