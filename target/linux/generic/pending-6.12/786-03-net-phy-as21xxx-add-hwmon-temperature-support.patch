From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Codex <codex@openai.com>
Date: Tue, 16 Jun 2026 00:00:00 -0700
Subject: [PATCH] net: phy: as21xxx: add hwmon temperature support

Expose the AS21xxx firmware temperature monitor through the standard hwmon
interface.

The upstream-style AS21xxx PHY driver already has the IPC transport helpers,
but the firmware temperature monitor used by the MTK OpenWrt 25.12 driver is
reached through the cfg-param direct path, not the IPC_CMD_TEMP_MON opcode.
The response layout and fixed-point conversion are based on the temperature
monitor path in MTK OpenWrt 25.12:

  target/linux/mediatek/patches-6.12/
  999-ephy-as21xxx-01-update-driver-to-v1.9.1.patch

This implementation is rewritten for the upstream-style AS21xxx driver and
uses Linux hwmon instead of the vendor debugfs interface.  The cfg-param
module number is intentionally kept as AS21XXX_CFG_TEMP_MON (11/0xb) because
the existing upstream define IPC_CFG_PARAM_DIRECT_TEMP_MON is 0x11 and does
not match the vendor v1.9.1 CFG_TEMP_MON value.

The hwmon init path configures continuous sampling and starts the firmware
temperature monitor once during probe.  Each read then follows the vendor
debugfs path by syncing IPC parity before sending the get-temperature command.

Signed-off-by: Codex <codex@openai.com>
---
 drivers/net/phy/as21xxx.c | 174 +++++++++++++++++++++++++++++++++++++-
 1 file changed, 173 insertions(+), 1 deletion(-)

--- a/drivers/net/phy/as21xxx.c
+++ b/drivers/net/phy/as21xxx.c
@@ -7,6 +7,8 @@
 
 #include <linux/bitfield.h>
 #include <linux/firmware.h>
+#include <linux/hwmon.h>
+#include <linux/math64.h>
 #include <linux/module.h>
 #include <linux/of.h>
 #include <linux/phy.h>
@@ -622,6 +624,172 @@ static int aeon_dpc_ra_enable(struct phy
 				 sizeof(data), NULL);
 }
 
+#if IS_REACHABLE(CONFIG_HWMON)
+#define AS21XXX_CFG_TEMP_MON			11
+#define AS21XXX_TEMP_REGS			3
+#define AS21XXX_TEMP_MON_START			1
+#define AS21XXX_TEMP_MON_CONFIG			3
+#define AS21XXX_TEMP_MON_GET			IPC_CMD_TEMP_MON_GET
+#define AS21XXX_TEMP_MON_CONTINUOUS		1
+
+static int as21xxx_hwmon_temp_monitor(struct phy_device *phydev,
+				      u16 sub_cmd, u16 param,
+				      u16 *ret_data)
+{
+	u16 scratch[AEON_IPC_DATA_NUM_REGISTERS];
+	u16 data[] = {
+		IPC_CFG_PARAM_DIRECT,
+		AS21XXX_CFG_TEMP_MON,
+		sub_cmd,
+		param,
+	};
+
+	if (!ret_data)
+		ret_data = scratch;
+
+	return aeon_ipc_send_msg(phydev, IPC_CMD_CFG_PARAM, data,
+				 sizeof(data), ret_data);
+}
+
+static int as21xxx_hwmon_init_temp_monitor(struct phy_device *phydev)
+{
+	struct as21xxx_priv *priv = phydev->priv;
+	int ret;
+
+	ret = aeon_ipc_sync_parity(phydev, priv);
+	if (ret)
+		return ret;
+
+	ret = as21xxx_hwmon_temp_monitor(phydev, AS21XXX_TEMP_MON_CONFIG,
+					 AS21XXX_TEMP_MON_CONTINUOUS, NULL);
+	if (ret < 0)
+		return ret;
+
+	ret = as21xxx_hwmon_temp_monitor(phydev, AS21XXX_TEMP_MON_START,
+					 0, NULL);
+	if (ret < 0)
+		return ret;
+
+	return 0;
+}
+
+static int as21xxx_hwmon_get_temp_regs(struct phy_device *phydev,
+				       u16 *ret_data)
+{
+	struct as21xxx_priv *priv = phydev->priv;
+	int ret;
+
+	ret = aeon_ipc_sync_parity(phydev, priv);
+	if (ret)
+		return ret;
+
+	ret = as21xxx_hwmon_temp_monitor(phydev, AS21XXX_TEMP_MON_GET,
+					 0, ret_data);
+	if (ret < 0)
+		return ret;
+
+	if (ret < AS21XXX_TEMP_REGS * sizeof(u16))
+		return -ENODATA;
+
+	return ret;
+}
+
+static int as21xxx_hwmon_get_temp(struct phy_device *phydev, long *val)
+{
+	u16 ret_data[AEON_IPC_DATA_NUM_REGISTERS];
+	s32 raw_temp;
+	int ret;
+
+	ret = as21xxx_hwmon_get_temp_regs(phydev, ret_data);
+	if (ret < 0)
+		return ret;
+
+	raw_temp = (s32)((u32)ret_data[1] | ((u32)ret_data[2] << 16));
+	*val = div_s64((s64)raw_temp * 1000, 65536);
+
+	return 0;
+}
+
+static umode_t as21xxx_hwmon_is_visible(const void *data,
+					enum hwmon_sensor_types type,
+					u32 attr, int channel)
+{
+	switch (type) {
+	case hwmon_temp:
+		switch (attr) {
+		case hwmon_temp_input:
+			return 0444;
+		default:
+			return 0;
+		}
+	default:
+		return 0;
+	}
+}
+
+static int as21xxx_hwmon_read(struct device *dev,
+			      enum hwmon_sensor_types type,
+			      u32 attr, int channel, long *val)
+{
+	struct phy_device *phydev = dev_get_drvdata(dev);
+
+	switch (type) {
+	case hwmon_temp:
+		switch (attr) {
+		case hwmon_temp_input:
+			return as21xxx_hwmon_get_temp(phydev, val);
+		default:
+			return -EOPNOTSUPP;
+		}
+	default:
+		return -EOPNOTSUPP;
+	}
+}
+
+static const struct hwmon_channel_info * const as21xxx_hwmon_info[] = {
+	HWMON_CHANNEL_INFO(temp, HWMON_T_INPUT),
+	NULL
+};
+
+static const struct hwmon_ops as21xxx_hwmon_ops = {
+	.is_visible	= as21xxx_hwmon_is_visible,
+	.read		= as21xxx_hwmon_read,
+};
+
+static const struct hwmon_chip_info as21xxx_hwmon_chip_info = {
+	.ops		= &as21xxx_hwmon_ops,
+	.info		= as21xxx_hwmon_info,
+};
+
+static int as21xxx_hwmon_register(struct phy_device *phydev)
+{
+	struct device *dev = &phydev->mdio.dev;
+	struct device *hwmon_dev;
+	char *hwmon_name;
+	int ret;
+
+	ret = as21xxx_hwmon_init_temp_monitor(phydev);
+	if (ret)
+		return ret;
+
+	hwmon_name = devm_hwmon_sanitize_name(dev, dev_name(dev));
+	if (IS_ERR(hwmon_name))
+		return PTR_ERR(hwmon_name);
+
+	hwmon_dev = devm_hwmon_device_register_with_info(dev, hwmon_name,
+							 phydev,
+							 &as21xxx_hwmon_chip_info,
+							 NULL);
+
+	return PTR_ERR_OR_ZERO(hwmon_dev);
+}
+#else
+static int as21xxx_hwmon_register(struct phy_device *phydev)
+{
+	return 0;
+}
+#endif
+
 static int as21xxx_probe(struct phy_device *phydev)
 {
 	struct as21xxx_priv *priv;
@@ -664,7 +832,11 @@ static int as21xxx_probe(struct phy_devi
 	if (ret)
 		return ret;
 
-	return aeon_dpc_ra_enable(phydev);
+	ret = aeon_dpc_ra_enable(phydev);
+	if (ret)
+		return ret;
+
+	return as21xxx_hwmon_register(phydev);
 }
 
 static int as21xxx_read_link(struct phy_device *phydev, int *bmcr)
-- 
2.45.2
